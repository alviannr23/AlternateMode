{
	"geode": "5.7.1",

	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},

	"id": "itsvinnity.alternate-mode",
	"name": "Alternate Mode",
	"version": "v1.0.0",
	"developer": "ItsVinnity",
	"description": "Force players to alternate between P1 and P2 inputs.",
	"repository": "https://github.com/alviannr23/AlternateMode",
	"tags": ["gameplay"],

	"settings": {

		"enabled": {
			"type": "bool",
			"name": "Enabled",
			"default": true
		},

		"hard-mode": {
			"type": "bool",
			"name": "Hard Mode",
			"description": "Instant die when wrong input.",
			"default": false
		},

		"show-indicator": {
			"type": "bool",
			"name": "Show Indicator",
			"default": true
		},

		"overlay-scale": {
			"type": "float",
			"name": "Overlay Scale",
			"default": 1.0,
			"min": 0.1,
			"max": 2.0,
			"step": 1
		},

		"overlay-offset-y": {
			"type": "float",
			"name": "Overlay Offset Y",
			"default": 0,
			"min": -20,
			"max": 250,
			"step": 1
		}
	},

	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	}
}